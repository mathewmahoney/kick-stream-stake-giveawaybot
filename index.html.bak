<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ICEINMYVEIN Giveaway's</title>
    <meta name="description" content="ICEINMYVEIN Giveaway's">

    <meta property="og:title" content="ICEINMYVEIN Giveaway">
    <meta property="og:description" content="ICEINMYVEIN Giveaway's">


    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="icon" href="/favicon.png" type="image/png" sizes="any">

    <style>
        :root {
            --bg-color: #020810;
            --primary-text-color: #ffffff;
            --secondary-text-color: #7aadcc;
            --primary-color: #00b4ff;
            /* Electric Blue */
            --light-blue: #7dd3fc;
            --panel-bg-color: rgba(4, 14, 32, 0.85);
            --border-color: rgba(0, 180, 255, 0.15);
            --error-color: #ff3366;
            /* Neon Pink-Red */
            --success-color: #7dd3fc;
            /* Light Blue */
            --warning-color: #60a5fa;
            /* Soft Blue */
            --accent-glow: 0 0 1rem rgba(0, 180, 255, 0.3);
            --accent-glow-strong: 0 0 2rem rgba(0, 180, 255, 0.6);
        }

        html {
            font-size: clamp(12px, 0.8333vw, 32px);
            height: 100%;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: radial-gradient(circle at center, #071428 0%, #020c1e 60%, #010508 100%);
            color: var(--primary-text-color);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 1rem;
            overflow-x: hidden;
        }

        #app-wrapper {
            width: 100%;
            max-width: 90rem;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        #app-container {
            width: 100%;
            background: var(--panel-bg-color);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(0, 180, 255, 0.2);
            border-radius: 1.25rem;
            box-shadow: 0 1.25rem 3.125rem rgba(0, 0, 0, 0.6), 0 0 2rem rgba(0, 180, 255, 0.06);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            height: min(56rem, calc(100vh - 2rem));
            max-height: min(56rem, calc(100vh - 2rem));
        }

        .screen {
            padding: 1.875rem;
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
            height: 100%;
            flex: 1;
            min-height: 0;
        }

        #login-screen {
            max-width: none;
            width: 100%;
            margin: 0;
            align-items: center;
            text-align: center;
            justify-content: center;
            padding: 2rem;
            gap: 1.875rem;
            height: 100%;
            overflow-y: auto;
        }

        h1 {
            color: var(--primary-color);
            font-size: 2.5rem;
            margin-bottom: 0.5rem;
            text-shadow: 0 0 1.5rem rgba(0, 180, 255, 0.5);
            font-weight: 700;
        }

        h2 {
            color: var(--primary-text-color);
            border-bottom: 2px solid rgba(255, 255, 255, 0.08);
            padding: 0.625rem 0;
            margin: 0 0 0.9375rem 0;
            font-weight: 600;
        }

        h3 {
            color: var(--primary-text-color);
            border-bottom: 2px solid rgba(255, 255, 255, 0.08);
            padding-bottom: 0.625rem;
            margin-bottom: 0.9375rem;
            font-weight: 600;
        }

        p {
            color: var(--secondary-text-color);
            margin-top: 0;
        }

        input[type="text"],
        input[type="number"],
        select {
            width: 100%;
            padding: 0.75rem 0.9375rem;
            border-radius: 0.75rem;
            border: 1px solid rgba(255, 255, 255, 0.08);
            background-color: rgba(0, 0, 0, 0.3);
            color: var(--primary-text-color);
            font-size: 1rem;
            font-family: 'Poppins', sans-serif;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        input[type="text"]:focus,
        input[type="number"]:focus,
        select:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 1rem rgba(0, 180, 255, 0.3);
            background-color: rgba(0, 0, 0, 0.4);
        }

        select {
            -webkit-appearance: none;
            appearance: none;
            background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%239c98b3' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
            background-repeat: no-repeat;
            background-position: right 1rem center;
            background-size: 1em;
            padding-right: 2.5rem;
        }

        button {
            width: 100%;
            padding: 0.75rem 0.9375rem;
            border-radius: 0.75rem;
            background: linear-gradient(135deg, #00b4ff 0%, #0060dd 100%);
            color: #ffffff;
            font-weight: 700;
            font-size: 1rem;
            font-family: 'Poppins', sans-serif;
            cursor: pointer;
            border: none;
            box-shadow: 0 4px 12px rgba(0, 180, 255, 0.25);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        button:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(0, 180, 255, 0.5);
            filter: brightness(1.05);
        }

        button:active:not(:disabled) {
            transform: translateY(0);
        }

        button:disabled {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.08);
            color: rgba(255, 255, 255, 0.2);
            box-shadow: none;
            cursor: not-allowed;
        }

        input:disabled {
            background-color: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.04);
            color: rgba(255, 255, 255, 0.2);
            cursor: not-allowed;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-bottom: 0.9375rem;
            border-bottom: 2px solid var(--border-color);
            flex-shrink: 0;
        }

        header .channel-info strong {
            color: var(--primary-color);
        }

        .header-menu-container {
            position: relative;
        }

        .icon-button {
            background: var(--border-color);
            width: 2.5rem;
            height: 2.5rem;
            padding: 0.5rem;
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .icon-button:hover {
            background-color: #4a4b50;
            filter: none;
        }

        .icon-button svg {
            stroke: var(--primary-text-color);
        }

        .header-menu-dropdown {
            position: absolute;
            top: calc(100% + 0.625rem);
            right: 0;
            width: 12.5rem;
            background-color: var(--panel-bg-color);
            border: 1px solid var(--border-color);
            border-radius: 0.5rem;
            box-shadow: 0 0.3125rem 0.9375rem rgba(0, 0, 0, 0.3);
            z-index: 10;
            display: flex;
            flex-direction: column;
            gap: 0.3125rem;
            padding: 0.3125rem;
            opacity: 0;
            visibility: hidden;
            transform: translateY(-0.625rem);
            transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
        }

        .header-menu-dropdown.active {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .header-menu-dropdown::before {
            content: '';
            position: absolute;
            top: -0.625rem;
            right: 0.875rem;
            border-left: 0.625rem solid transparent;
            border-right: 0.625rem solid transparent;
            border-bottom: 0.625rem solid var(--border-color);
        }

        .header-menu-dropdown .small-button {
            text-align: left;
        }

        .small-button {
            width: 100%;
            padding: 0.5rem 0.75rem;
            font-size: 0.9rem;
            background-color: var(--border-color);
            color: var(--primary-text-color);
        }

        .small-button:hover {
            background-color: #4a4b50;
            filter: none;
        }

        .danger-button {
            background-color: var(--error-color);
            color: var(--primary-text-color);
        }

        .danger-button:hover {
            background-color: #c0392b;
        }

        .main-content {
            display: grid;
            grid-template-columns: 21.875rem 1fr 25rem;
            gap: 1.875rem;
            height: 100%;
            align-items: stretch;
        }


        .settings-panel {
            display: flex;
            flex-direction: column;
            height: 100%;
            justify-content: space-between;
        }

        .settings-controls-container {
            display: flex;
            flex-direction: column;
            flex-grow: 1;
            justify-content: flex-start;
            padding: 0.25rem;
            margin-bottom: 1rem;
            margin-top: 0;
            gap: 0.75rem;
            overflow-y: auto;
            scrollbar-width: thin;
        }

        .start-section {
            margin-top: 0;
            flex-shrink: 0;
        }

        .settings-panel label {
            color: var(--secondary-text-color);
            font-size: 0.85rem;
            margin-bottom: 0.1rem;
        }

        .settings-panel>label>span {
            color: var(--primary-text-color);
            font-weight: 600;
        }


        .settings-row {
            display: flex;
            gap: 0.625rem;
            align-items: flex-end;
            width: 100%;
        }

        .input-group {
            display: flex;
            flex-direction: column;
            gap: 0.8rem;
            width: 100%;
        }

        .width-66 {
            flex: 2;
        }

        .width-33 {
            flex: 1;
        }

        .width-50 {
            flex: 1;
        }

        .checkbox-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            padding: 0.2rem 0;
        }

        .checkbox-wrapper label {
            display: inline-flex;
            align-items: center;
            gap: 0.625rem;
            cursor: pointer;
        }

        .checkbox-wrapper input[type="checkbox"] {
            -webkit-appearance: none;
            appearance: none;
            width: 2.75rem;
            height: 1.5rem;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 0.75rem;
            position: relative;
            cursor: pointer;
            outline: none;
            transition: all .2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .checkbox-wrapper input[type="checkbox"]::before {
            content: '';
            position: absolute;
            top: 0.125rem;
            left: 0.125rem;
            width: 1.125rem;
            height: 1.125rem;
            background: var(--primary-text-color);
            border-radius: 50%;
            transition: transform .2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .checkbox-wrapper input[type="checkbox"]:checked {
            background: var(--primary-color);
            box-shadow: 0 0 8px rgba(0, 180, 255, 0.5);
        }

        .checkbox-wrapper input[type="checkbox"]:checked::before {
            transform: translateX(1.25rem);
            background: #ffffff;
        }

        .checkbox-wrapper input[type="checkbox"]:disabled {
            background: rgba(255, 255, 255, 0.02);
            border-color: rgba(255, 255, 255, 0.04);
            cursor: not-allowed;
            opacity: .55;
        }

        .checkbox-wrapper input[type="checkbox"]:disabled::before {
            background: rgba(255, 255, 255, 0.15);
        }

        .checkbox-wrapper input[type="checkbox"]:checked:disabled {
            background: rgba(0, 180, 255, 0.2);
            box-shadow: none;
        }

        .checkbox-wrapper input[type="checkbox"]:checked:disabled::before {
            background: rgba(0, 0, 0, 0.4);
        }

        input[type=range] {
            padding: 0;
            -webkit-appearance: none;
            background: transparent;
            width: 100%;
        }

        input[type=range]::-webkit-slider-runnable-track {
            height: 0.5rem;
            background: rgba(0, 0, 0, 0.35);
            border-radius: 0.3125rem;
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        input[type=range]::-webkit-slider-thumb {
            -webkit-appearance: none;
            height: 1.25rem;
            width: 1.25rem;
            background: var(--primary-color);
            box-shadow: 0 0 8px rgba(0, 180, 255, 0.5);
            border-radius: 50%;
            margin-top: -0.4375rem;
            cursor: pointer;
            transition: transform 0.1s ease;
        }

        input[type=range]::-webkit-slider-thumb:hover {
            transform: scale(1.2);
        }


        .info-tooltip {
            cursor: help;
            font-size: 0.9rem;
            color: var(--primary-color);
            margin-left: 0.3rem;
            position: relative;
            display: inline-flex;
            justify-content: center;
            align-items: center;
            width: 1.2rem;
            height: 1.2rem;
            border: 1px solid var(--primary-color);
            border-radius: 50%;
            background: rgba(0, 180, 255, 0.1);
            z-index: 50;
        }


        .info-tooltip .tooltip-content {
            opacity: 0;
            visibility: hidden;

            pointer-events: auto;
            user-select: text;
            -webkit-user-select: text;
            cursor: text;

            position: absolute;
            bottom: 100%;
            left: 50%;
            transform: translateX(-50%);
            margin-bottom: 10px;
            z-index: 1000;

            background-color: #222;
            color: #fff;
            border: 1px solid var(--border-color);
            padding: 0.6rem;
            border-radius: 0.4rem;
            font-size: 0.75rem;
            font-weight: 200;
            white-space: normal;
            width: 22rem;
            text-align: center;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.5);

            transition: opacity 0.2s ease 0.3s, visibility 0.2s ease 0.3s, margin-bottom 0.2s ease 0.3s;
        }

        .info-tooltip .tooltip-content::before {
            content: '';
            position: absolute;
            top: 100%;
            left: 50%;
            transform: translateX(-50%);
            border-width: 6px;
            border-style: solid;
            border-color: #222 transparent transparent transparent;
        }

        .info-tooltip .tooltip-content::after {
            content: '';
            position: absolute;
            top: 100%;
            left: 0;
            width: 100%;
            height: 15px;
            background: transparent;
        }

        .info-tooltip:hover .tooltip-content,
        .info-tooltip .tooltip-content:hover {
            opacity: 1;
            visibility: visible;
            margin-bottom: 15px;
            transition-delay: 0s;
        }


        #status-message {
            font-size: 0.9rem;
            padding-top: 0.9375rem;
            text-align: center;
            font-weight: 600;
        }

        .status-waiting {
            color: var(--secondary-text-color);
        }

        .status-connected {
            color: var(--success-color);
        }

        .status-error {
            color: var(--error-color);
        }

        .giveaway-panel,
        .winners-panel {
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        .winners-panel::after {
            content: '';
            display: block;
            height: 4.3125rem;
            flex: 0 0 auto;
        }

        #participant-list,
        #winners-list {
            list-style: none;

            flex-grow: 1;

            height: 0;
            min-height: 0;

            overflow-y: auto;
            background: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 0.5rem;
            padding: 0.625rem;
        }

        #participant-list li {
            padding: 0.5rem 0.75rem;
            border-bottom: 1px solid var(--border-color);
            font-size: 0.95rem;
            animation: fadeIn 0.3s ease;
        }

        #participant-list li:last-child {
            border-bottom: none;
        }

        #participant-list li.subscriber {
            color: var(--primary-color);
            font-weight: 600;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-0.625rem);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        #winners-list li {
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: all 0.3s ease;
            padding: 0.5rem 0.75rem;
            border-bottom: 1px solid var(--border-color);
        }

        .winner-name-span {
            font-size: 0.95rem;
            font-weight: 600;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .winner-date-span {
            font-size: 0.7rem;
            color: var(--secondary-text-color);
            flex-shrink: 0;
            margin-left: 0.625rem;
        }

        #winners-list li.confirmed .winner-name-span {
            color: var(--success-color);
        }

        #winners-list li.confirmed .winner-name-span::before {
            content: '✓ ';
        }

        #winners-list li.failed .winner-name-span {
            color: var(--error-color);
            text-decoration: line-through;
        }

        #winners-list li.failed .winner-name-span::before {
            content: '✗ ';
        }

        .action-buttons {
            display: flex;
            gap: 0.9375rem;
            margin-top: 1.25rem;
            flex-shrink: 0;
        }

        .action-buttons button {
            width: auto !important;
        }

        #draw-button {
            flex: 2 1 0;
        }

        #reset-button {
            background: #e9113c;
            flex: 1 0 0;
            color: #fff;
        }

        #reset-button:hover {
            background: #b50d2f;
        }

        #claim-section {
            margin-top: 0.9375rem;
            padding: 0.9375rem;
            border: 1px solid var(--warning-color);
            border-radius: 0.5rem;
            background-color: var(--bg-color);
            display: none;
            flex-direction: column;
            gap: 0.625rem;
        }

        #claim-section h3 {
            font-size: 1.1rem;
            border: none;
            margin: 0;
            padding: 0;
        }

        #claim-section h3 span {
            color: var(--primary-color);
        }

        #claim-countdown {
            font-weight: 600;
            color: var(--warning-color);
            transition: color 0.3s;
        }

        #claim-countdown.confirmed {
            color: var(--success-color);
        }

        #claim-countdown.failed {
            color: var(--error-color);
        }

        #claim-chat-log {
            list-style: none;
            height: 6.25rem;
            overflow-y: auto;
            font-size: 0.9rem;
            background: #111;
            padding: 0.5rem;
            border-radius: 0.25rem;
        }

        #claim-chat-log li {
            padding: 0.25rem;
            border-bottom: 1px solid var(--border-color);
            color: var(--secondary-text-color);
        }

        #claim-confirm-button {
            margin-top: 0.625rem;
            display: none;
        }

        #multi-winner-modal-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.85);
            display: none;
            flex-direction: column;
            justify-content: flex-start;
            align-items: center;
            gap: 2.5rem;
            padding: 2.5rem 1.25rem;
            z-index: 1000;
            backdrop-filter: blur(0.3125rem);
            overflow-y: auto;
        }

        .modal-row {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 2.5rem;
            width: 100%;
            flex-wrap: wrap;
            margin: auto;
        }

        .modal-instance {
            display: flex;
            width: 100%;
            max-width: 29.375rem;
            min-width: 18.75rem;
            flex-grow: 1;
            flex-shrink: 1;
            transition: opacity 0.3s, transform 0.3s;
            align-items: center;
        }

        .modal-instance.is-hidden {
            opacity: 0;
            visibility: hidden;
            transform: scale(0.9);
            pointer-events: none;
        }

        .modal-content {
            background-color: var(--panel-bg-color);
            padding: 1.5rem;
            border-radius: 0.75rem;
            text-align: center;
            border: 1px solid var(--primary-color);
            box-shadow: 0 0 1.5rem rgba(0, 180, 255, 0.35), 0 0 3rem rgba(0, 96, 221, 0.15);
            display: flex;
            flex-direction: column;
            gap: 1rem;
            min-height: 23.75rem;
            height: auto;
            max-height: 90vh;
            width: 100%;
            justify-content: space-between;
            overflow-y: auto;
            scrollbar-width: thin;
        }

        .winner-animation-box {
            font-family: 'Poppins', monospace;
            width: 100%;
            height: min(13.75rem, 25vh);
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            margin: 0 auto;
        }

        h1.winner-name {
            font-size: clamp(2rem, 5vw, 3.5rem);
            word-break: break-all;
            line-height: 1.1;
            color: var(--primary-text-color);
        }

        h1.winner-name.winner {
            color: var(--primary-color);
            text-shadow: 0 0 0.9375rem var(--primary-color);
        }

        .wheel-animation-container {
            position: relative;
            height: 100%;
            width: 100%;
            overflow: hidden;
            border-top: 2px solid var(--border-color);
            border-bottom: 2px solid var(--border-color);
            mask-image: linear-gradient(to bottom, transparent, black 20%, black 80%, transparent);
            -webkit-mask-image: linear-gradient(to bottom, transparent, black 20%, black 80%, transparent);
            transform: scaleY(-1);
        }

        .wheel-animation-container::after {
            content: '';
            position: absolute;
            left: 0.625rem;
            top: 50%;
            transform: translateY(-50%) scaleY(-1);
            width: calc(100% - 1.25rem);
            height: 3.125rem;
            background-color: rgba(0, 180, 255, 0.1);
            border-top: 2px solid var(--primary-color);
            border-bottom: 2px solid var(--primary-color);
            border-radius: 0.5rem;
            z-index: 1;
        }

        .wheel-list {
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
            list-style: none;
            padding: 0;
            margin: 0;
            text-align: center;
            transition: transform 7s cubic-bezier(0.2, 0.9, 0.3, 1);
        }

        .wheel-list li {
            height: 3.125rem;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 1.8rem;
            color: var(--secondary-text-color);
            font-weight: 600;
            padding: 0 0.625rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            transition: all 0.3s;
            transform: scaleY(-1);
        }

        .wheel-list.finished li.winner {
            color: var(--primary-color);
            text-shadow: 0 0 0.625rem var(--primary-color);
            transform: scaleY(-1) scale(1.1);
        }


        @keyframes infiniteSpin {
            0% {
                transform: translateY(0);
            }

            100% {
                transform: translateY(-50%);
            }
        }

        .modal-confirm-button {
            align-self: center;
            visibility: hidden;
        }

        .modal-winner-chat-log {
            list-style: none;
            max-height: min(11.875rem, 20vh);
            overflow-y: auto;
            font-size: 0.9rem;
            background: #111;
            padding: 0.25rem 0.5rem;
            border-radius: 0.25rem;
            margin-top: 0.9375rem;
            display: none;
            text-align: left;
        }

        .modal-winner-chat-log li {
            padding: 0.25rem;
            border-bottom: 1px solid var(--border-color);
            color: var(--secondary-text-color);
            word-break: break-word;
        }

        .modal-winner-chat-log li:last-child {
            border-bottom: none;
        }

        footer {
            text-align: center;
            padding: 6rem 1.25rem;
            color: var(--secondary-text-color);
            font-size: 0.8rem;
            line-height: 1.6;
        }

        footer p {
            margin-bottom: 0.3125rem;
        }

        footer p.cookie-note {
            font-size: 0.65rem;
            color: var(--secondary-text-color);
        }

        footer .cookie-note a,
        footer .cookie-note a:visited {
            color: inherit;
            text-decoration: underline;
        }

        body.modal-active #participant-list,
        body.modal-active #winners-list {
            background-color: transparent;
            border-color: transparent;
            pointer-events: none;
        }

        body.modal-active #participant-list *,
        body.modal-active #winners-list * {
            color: transparent !important;
            text-shadow: none !important;
        }

        /* Overlay mode styling */
        body.overlay-mode {
            background: transparent !important;
            padding: 0 !important;
            margin: 0 !important;
            height: 100vh !important;
            width: 100vw !important;
            overflow: hidden !important;
        }

        body.overlay-mode #overlay-placeholder {
            display: flex;
            height: 100vh;
            width: 100vw;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            text-align: center;
            color: var(--secondary-text-color);
            font-size: 1.5rem;
            padding: 2rem;
            box-sizing: border-box;
            background: radial-gradient(circle at center, #071428 0%, #020c1e 60%, #010508 100%);
        }

        body.overlay-mode #multi-winner-modal-container {
            background-color: rgba(5, 4, 10, 0.95);
            backdrop-filter: blur(8px);
            padding: 2rem;
            display: none;
            justify-content: center;
            align-items: center;
            height: 100vh;
            width: 100vw;
        }

        body.overlay-mode .modal-content {
            box-shadow: 0 0 3rem rgba(0, 180, 255, 0.4);
            border: 2px solid var(--primary-color);
            background-color: rgba(4, 14, 32, 0.97);
        }

        body.overlay-mode .modal-instance {
            max-width: 35rem;
        }

        #login-screen #channel-input {
            width: 75%;
            max-width: 15.625rem;
            align-self: center;
        }

        #login-screen #connect-button {
            width: 75%;
            max-width: 12.5rem;
            align-self: center;
        }


        @media (max-width: 1024px),
        (max-height: 680px) {
            body {
                padding: 1rem;
            }

            #app-container {
                min-height: auto;
                max-height: none;
                height: auto;
            }

            #login-screen {
                padding: 3rem 1.5rem 1.5rem;
            }

            .main-content {
                grid-template-columns: 1fr;
                gap: 2rem;
            }

            #participant-list,
            #winners-list {
                min-height: 12.5rem;
                max-height: 40vh;
            }

            .winners-panel::after {
                display: none;
            }

            .settings-panel>button#start-giveaway-button {
                margin-top: 1.5rem;
            }

            .settings-controls-container {
                gap: 1rem;
                justify-content: flex-start;
                overflow-y: visible;
            }
        }

        #participant-list,
        #winners-list,
        #claim-chat-log,
        .modal-winner-chat-log,
        #multi-winner-modal-container {
            scrollbar-width: thin;
            scrollbar-color: var(--border-color) var(--bg-color);
        }


        #participant-list::-webkit-scrollbar,
        #winners-list::-webkit-scrollbar,
        #claim-chat-log::-webkit-scrollbar,
        .modal-winner-chat-log::-webkit-scrollbar,
        #multi-winner-modal-container::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        #participant-list::-webkit-scrollbar-track,
        #winners-list::-webkit-scrollbar-track,
        #claim-chat-log::-webkit-scrollbar-track,
        .modal-winner-chat-log::-webkit-scrollbar-track,
        #multi-winner-modal-container::-webkit-scrollbar-track {
            background: transparent;
        }

        #participant-list::-webkit-scrollbar-thumb,
        #winners-list::-webkit-scrollbar-thumb,
        #claim-chat-log::-webkit-scrollbar-thumb,
        .modal-winner-chat-log::-webkit-scrollbar-thumb,
        #multi-winner-modal-container::-webkit-scrollbar-thumb {
            background-color: var(--border-color);
            border-radius: 10px;

            border: 2px solid var(--bg-color);
        }


        #claim-chat-log::-webkit-scrollbar-thumb,
        .modal-winner-chat-log::-webkit-scrollbar-thumb {
            border: 2px solid #111;
        }

        #participant-list::-webkit-scrollbar-thumb:hover,
        #winners-list::-webkit-scrollbar-thumb:hover,
        #claim-chat-log::-webkit-scrollbar-thumb:hover,
        .modal-winner-chat-log::-webkit-scrollbar-thumb:hover,
        #multi-winner-modal-container::-webkit-scrollbar-thumb:hover {
            background-color: #4a4b50;
        }

        html,
        body {
            scrollbar-width: thin;
            scrollbar-color: var(--border-color) var(--bg-color);
        }

        html::-webkit-scrollbar,
        body::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        html::-webkit-scrollbar-track,
        body::-webkit-scrollbar-track {
            background: transparent;
        }

        html::-webkit-scrollbar-thumb,
        body::-webkit-scrollbar-thumb {
            background-color: var(--border-color);
            border-radius: 10px;
            border: 2px solid var(--bg-color);
        }

        html::-webkit-scrollbar-thumb:hover,
        body::-webkit-scrollbar-thumb:hover {
            background-color: #4a4b50;
        }

        .winner-animation-box {
            transition: opacity 0.2s ease-in-out;
            opacity: 1;
        }


        .winner-animation-box.fade-out {
            opacity: 0;
        }


        .modal-winner-chat-log.waiting {
            display: flex !important;
            justify-content: center;
            align-items: center;
            height: 2.5rem;
            overflow: hidden;
        }

        .modal-winner-chat-log.waiting::after {
            content: '';
            width: 5px;
            height: 5px;
            border-radius: 50%;

            animation: typing-sequence 1.5s infinite ease-in-out;
        }

        @keyframes typing-sequence {

            0%,
            100% {
                box-shadow: -12px 0 0 0 rgba(255, 255, 255, 1),
                    12px 0 0 0 rgba(255, 255, 255, 0.5);
                background-color: rgba(255, 255, 255, 0.5);
            }

            33% {
                box-shadow: -12px 0 0 0 rgba(255, 255, 255, 0.5),
                    12px 0 0 0 rgba(255, 255, 255, 0.5);
                background-color: rgba(255, 255, 255, 1);
            }

            66% {
                box-shadow: -12px 0 0 0 rgba(255, 255, 255, 0.5),
                    12px 0 0 0 rgba(255, 255, 255, 1);
                background-color: rgba(255, 255, 255, 0.5);
            }
        }


        .editable-number {
            cursor: text;
            padding: 0 4px;
            min-width: 10px;
            display: inline-block;
            text-align: center;
            outline: none;

            text-decoration: underline;
            text-decoration-style: dashed;


            text-decoration-color: rgba(0, 180, 255, 0.4);

            text-decoration-thickness: 1px;


            text-underline-offset: 4px;
        }


        .editable-number[contenteditable="false"] {
            cursor: default;
            text-decoration: none;
        }

        .randomness-source-badge {
            font-size: 0.75rem;
            color: var(--secondary-text-color);
            background: rgba(0, 0, 0, 0.2);
            border: 1px solid var(--border-color);
            border-radius: 1rem;
            padding: 0.25rem 0.75rem;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            margin: 0.5rem auto 0 auto;
            width: fit-content;
        }

        .randomness-source-badge .dot {
            width: 0.5rem;
            height: 0.5rem;
            border-radius: 50%;
            display: inline-block;
            background-color: var(--secondary-text-color);
            animation: pulse 1.5s infinite ease-in-out;
        }

        @keyframes pulse {

            0%,
            100% {
                opacity: 0.4;
            }

            50% {
                opacity: 1;
            }
        }

        .randomness-source-badge.random-org {
            border-color: rgba(0, 180, 255, 0.4);
            color: var(--success-color);
        }

        .randomness-source-badge.random-org .dot {
            background-color: var(--success-color);
            box-shadow: 0 0 0.5rem var(--success-color);
            animation: none;
            opacity: 1;
        }

        .randomness-source-badge.fallback {
            border-color: rgba(96, 165, 250, 0.4);
            color: var(--warning-color);
        }

        .randomness-source-badge.fallback .dot {
            background-color: var(--warning-color);
            box-shadow: 0 0 0.5rem var(--warning-color);
            animation: none;
            opacity: 1;
        }

        .winner-source-tag {
            font-size: 0.65rem;
            padding: 0.1rem 0.4rem;
            border-radius: 0.25rem;
            font-weight: 600;
            margin-left: 0.5rem;
            text-transform: uppercase;
            display: inline-block;
            vertical-align: middle;
        }

        .winner-source-tag.random-org {
            background: rgba(0, 180, 255, 0.12);
            color: var(--primary-color);
            border: 1px solid rgba(0, 180, 255, 0.3);
        }

        .winner-source-tag.fallback {
            background: rgba(96, 165, 250, 0.12);
            color: var(--warning-color);
            border: 1px solid rgba(96, 165, 250, 0.3);
        }

        .modal-claim-container {
            margin-top: 0.5rem;
            padding: 0.8rem;
            border: 1px solid var(--border-color);
            border-radius: 0.5rem;
            background: rgba(0, 0, 0, 0.2);
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
            align-items: center;
        }

        .modal-claim-instruction {
            font-size: 0.85rem;
            color: var(--secondary-text-color);
            text-align: center;
        }

        .modal-claim-countdown {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--primary-text-color);
        }

        .modal-claim-countdown.confirmed {
            color: var(--success-color);
            font-size: 1.25rem;
        }

        .modal-claim-countdown.failed {
            color: var(--error-color);
            font-size: 0.95rem;
            font-weight: 600;
            line-height: 1.4;
            text-align: center;
        }

        .modal-claim-buttons {
            display: flex;
            gap: 1rem;
            width: 100%;
            margin-top: 0.5rem;
        }

        .modal-claim-buttons button {
            flex: 1;
        }

        #api-status-box {
            display: none;
            margin-top: 1.25rem;
            padding: 0.75rem 1rem;
            background-color: rgba(231, 76, 60, 0.1);
            border: 1px solid rgba(231, 76, 60, 0.3);
            border-radius: 0.5rem;
            color: var(--primary-text-color);
            font-size: 0.85rem;
            text-align: center;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            flex-shrink: 0;
            width: 100%;
        }

        #api-status-box.active {
            display: flex;
        }

        #api-status-box .error-title {
            color: var(--error-color);
            font-weight: 600;
        }
    </style>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
</head>

<body>

    <div id="app-wrapper">

        <div id="app-container" data-nosnippet>
            <div id="login-screen" class="screen">
                <h1 data-lang-key="loginTitle">www.iceinmyvein.com</h1>
                <p data-lang-key="loginPrompt">ICEINMYVEIN channel for the giveaway</p>
                <input type="text" id="channel-input" data-lang-key-placeholder="loginPlaceholder"
                    placeholder="E.g., xqc">
                <button id="connect-button" data-lang-key="connectButton">Connect</button>
            </div>

            <div id="main-screen" class="screen" style="display: none;">
                <header>
                    <div class="channel-info">
                        <span data-lang-key="connectedTo">Connected to:<img src="/logo.png" alt="logo"></span> <strong
                            id="connected-channel-name"></strong>
                    </div>
                    <div id="header-menu-container" class="header-menu-container">
                        <button id="header-menu-toggle" class="icon-button" data-lang-key-aria-label="settingsMenuAria">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                stroke-linejoin="round">
                                <circle cx="12" cy="12" r="3"></circle>
                                <path
                                    d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82-.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06-.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z">
                                </path>
                            </svg>
                        </button>
                        <div id="header-menu-dropdown" class="header-menu-dropdown">
                            <button id="change-channel-button" class="small-button" data-lang-key="changeChannel">Change
                                Channel</button>
                            <button id="clear-all-data-button" class="small-button danger-button"
                                data-lang-key="clearAllData">Clear All Data</button>
                        </div>
                    </div>
                </header>

                <div class="main-content">
                    <div class="settings-panel">
                        <h2 data-lang-key="settingsTitle">Settings</h2>

                        <div class="settings-controls-container">


                            <div class="settings-row">
                                <div class="input-group width-66">
                                    <label for="keyword-input" data-lang-key="keywordLabel">Keyword (optional):</label>
                                    <input type="text" id="keyword-input" placeholder="">
                                </div>
                                <div class="input-group width-33">
                                    <label for="winner-count-input" data-lang-key="winnerCountLabel">Winners:</label>
                                    <input type="number" id="winner-count-input" value="1" min="1" max="10">
                                </div>
                            </div>





                            <div class="input-group">
                                <label for="sub-length-slider">
                                    <span data-lang-key="subLengthLabel">Subscription Duration:</span>
                                    <span id="sub-length-value">0</span> <span data-lang-key="monthsLabel">Months</span>
                                </label>
                                <input type="range" id="sub-length-slider" min="0" max="60" value="0">
                            </div>


                            <div class="input-group">
                                <label for="sub-multiplier-slider">
                                    <span data-lang-key="subMultiplierLabel">Subscriber Multiplier:</span>
                                    <span id="sub-multiplier-value">1</span>x
                                </label>
                                <input type="range" id="sub-multiplier-slider" min="1" max="10" value="1">
                            </div>

                            <div class="input-group">
                                <label for="follow-length-slider">
                                    <span data-lang-key="followLengthLabel">Follow Duration:</span>

                                    <span id="follow-length-value" contenteditable="true"
                                        class="editable-number">0</span> <span data-lang-key="daysLabel">Days</span>

                                    <span class="info-tooltip">!
                                        <span class="tooltip-content" data-lang-key="followTooltip"></span>
                                    </span>
                                </label>
                                <input type="range" id="follow-length-slider" min="0" max="365" value="0">
                            </div>


                            <div class="checkbox-group">
                                <div class="checkbox-wrapper">
                                    <label for="sub-only-checkbox">
                                        <input type="checkbox" id="sub-only-checkbox">
                                        <span data-lang-key="subOnlyLabel">Subscribers only</span>
                                    </label>
                                </div>

                                <div class="checkbox-wrapper">
                                    <label for="winner-claim-checkbox">
                                        <input type="checkbox" id="winner-claim-checkbox">
                                        <span data-lang-key="winnerClaimLabel">Winner confirmation</span>
                                    </label>
                                </div>

                                <div class="checkbox-wrapper">
                                    <label for="repeat-winners-checkbox">
                                        <input type="checkbox" id="repeat-winners-checkbox">
                                        <span>Allow repeat winners</span>
                                    </label>
                                </div>
                            </div>


                            <div class="settings-row">
                                <div class="input-group width-50">
                                    <label for="claim-duration-input" data-lang-key="claimDurationLabel">Confirm Time
                                        (s):</label>
                                    <input type="number" id="claim-duration-input" value="30" min="10">
                                </div>
                                <div class="input-group width-50">
                                    <label for="animation-select" data-lang-key="animationLabel">Animation:</label>
                                    <select id="animation-select">
                                        <option value="wheel" selected data-lang-key="animationWheel">Wheel</option>
                                        <option value="slot-machine" data-lang-key="animationClassic">Classic</option>
                                        <option value="char-scramble" data-lang-key="animationScramble">Scramble
                                        </option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="start-section" style="display: flex; flex-direction: column; gap: 0.75rem;">
                            <button id="open-overlay-button" type="button"
                                style="background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); color: #fff; width: 100%; box-shadow: none;">📺
                                Open Stream Overlay</button>
                            <button id="start-giveaway-button" data-lang-key="startGiveawayButton">Start
                                Giveaway</button>
                            <p id="status-message" class="status-waiting" data-lang-key="statusWaiting">Press "Start" to
                                connect to the chat.</p>
                        </div>
                    </div>

                    <div class="giveaway-panel">
                        <h2><span data-lang-key="participantsTitle">Participants</span> (<span
                                id="participant-count">0</span>)</h2>
                        <ul id="participant-list"></ul>

                        <div id="claim-section">
                            <h3 data-lang-key="claimTitle">Awaiting Confirmation: <span id="claim-winner-name"></span>
                            </h3>
                            <p id="claim-countdown"></p>
                            <ul id="claim-chat-log"></ul>
                            <button id="claim-confirm-button" class="small-button" data-lang-key="okButton">OK</button>
                        </div>

                        <div class="action-buttons">
                            <button id="draw-button" data-lang-key="drawButton">Draw Winner</button>
                            <button id="reset-button" data-lang-key="resetButton">Reset</button>
                        </div>
                        <div id="test-sandbox"
                            style="display: none; padding: 10px; background: #222; border: 1px solid var(--primary-color); border-radius: 4px; gap: 10px; margin-top: 10px; margin-bottom: 10px;">
                            <button id="add-test-participants-btn" class="small-button">Add 3 Test Participants</button>
                        </div>
                    </div>

                    <div class="winners-panel">
                        <h2><span data-lang-key="winnersTitle">Winners</span> (<span id="winners-count">0</span>)</h2>
                        <ul id="winners-list"></ul>
                    </div>
                </div>
            </div>
        </div>


        <footer>
            <p>This App has been created by - Suchadesign 2026</p>
        </footer>
    </div>

    <div id="multi-winner-modal-container"></div>

    <div id="overlay-placeholder"
        style="display: none; height: 100vh; width: 100vw; justify-content: center; align-items: center; flex-direction: column; text-align: center; color: var(--secondary-text-color); font-size: 1.5rem; padding: 2rem; box-sizing: border-box; background: radial-gradient(circle at center, #071428 0%, #020c1e 60%, #010508 100%);">
        <div
            style="border: 2px dashed rgba(0, 180, 255, 0.25); padding: 4rem 2rem; border-radius: 1.5rem; max-width: 600px; width: 100%; box-shadow: inset 0 0 2rem rgba(0, 180, 255, 0.04), 0 0 2rem rgba(0,0,0,0.5);">
            <h2
                style="color: var(--primary-color); border: none; margin-bottom: 1rem; text-shadow: 0 0 1.25rem rgba(0, 180, 255, 0.5); font-size: 2.2rem; font-weight: 700;">
                A Winner Will Be Drawn Shortly!</h2>
            <p style="font-size: 1.1rem; color: var(--secondary-text-color);">Ready for stream capture. Waiting for
                drawings...</p>
        </div>
    </div>

    <div id="modal-template" style="display: none;">
        <div class="modal-instance">
            <div class="modal-content">
                <p class="modal-fun-fact"
                    style="font-size: 0.75rem; color: var(--secondary-text-color); margin-bottom: -0.25rem; line-height: 1.3;">
                    Fun Fact: This bot uses a true randomly selected winner using static electricity in the environment.
                </p>
                <p class="winner-title-text" data-lang-key="modalDrawing">Drawing...</p>
                <div class="winner-animation-box"></div>
                <div class="randomness-source-badge">
                    <span class="dot"></span>
                    <span class="badge-text">Verifying randomness...</span>
                </div>

                <div class="modal-claim-container" style="display: none;">
                    <p class="modal-claim-instruction">If this is you, enter something into the chat before your time
                        runs out.</p>
                    <p class="modal-claim-countdown">30s</p>
                    <div class="modal-claim-buttons" style="display: none;">
                        <button class="modal-redraw-button small-button">Redraw Winner</button>
                        <button class="modal-cancel-button small-button danger-button">Cancel</button>
                    </div>
                </div>

                <button class="modal-confirm-button small-button" data-lang-key="okButton">OK</button>
                <ul class="modal-winner-chat-log"></ul>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {

            const loginScreen = document.getElementById('login-screen'),
                mainScreen = document.getElementById('main-screen'),
                channelInput = document.getElementById('channel-input'),
                connectButton = document.getElementById('connect-button'),
                connectedChannelName = document.getElementById('connected-channel-name');

            const headerMenuContainer = document.getElementById('header-menu-container'),
                headerMenuToggle = document.getElementById('header-menu-toggle'),
                headerMenuDropdown = document.getElementById('header-menu-dropdown'),
                changeChannelButton = document.getElementById('change-channel-button'),
                clearAllDataButton = document.getElementById('clear-all-data-button');

            const settingsPanel = document.querySelector('.settings-panel'),
                keywordInput = document.getElementById('keyword-input'),
                winnerCountInput = document.getElementById('winner-count-input'),
                subOnlyCheckbox = document.getElementById('sub-only-checkbox'),
                subMultiplierSlider = document.getElementById('sub-multiplier-slider'),
                subMultiplierValue = document.getElementById('sub-multiplier-value'),
                winnerClaimCheckbox = document.getElementById('winner-claim-checkbox'),
                repeatWinnersCheckbox = document.getElementById('repeat-winners-checkbox'),
                claimDurationInput = document.getElementById('claim-duration-input'),
                animationSelect = document.getElementById('animation-select'),
                startGiveawayButton = document.getElementById('start-giveaway-button'),
                statusMessage = document.getElementById('status-message');


            const followLengthSlider = document.getElementById('follow-length-slider'),
                followLengthValue = document.getElementById('follow-length-value'),
                subLengthSlider = document.getElementById('sub-length-slider'),
                subLengthValue = document.getElementById('sub-length-value');

            const participantCount = document.getElementById('participant-count'),
                participantList = document.getElementById('participant-list'),
                drawButton = document.getElementById('draw-button'),
                resetButton = document.getElementById('reset-button');

            const winnersCount = document.getElementById('winners-count'),
                winnersList = document.getElementById('winners-list');

            const claimSection = document.getElementById('claim-section'),
                claimWinnerName = document.getElementById('claim-winner-name'),
                claimCountdown = document.getElementById('claim-countdown'),
                claimChatLog = document.getElementById('claim-chat-log'),
                claimConfirmButton = document.getElementById('claim-confirm-button');

            const modalTemplate = document.getElementById('modal-template');
            const multiWinnerModalContainer = document.getElementById('multi-winner-modal-container');

            let kickChannelName = '', kickChannelSlug = '', kickChatroomId = null, channelCreationDate = null, ws = null;
            let giveawayKeyword = '', isGiveawayRunning = false, isDrawInProgress = false;
            let participants = new Set(), allEntries = [], winners = [];
            let modalChatWinners = [], claimInterval = null, lastClaimWinner = null;
            let pendingAnimationInterval = null;
            let activeModalClaim = null;
            let overlayWindow = null;

            window.isOverlayMode = window.location.search.includes('overlay=true');
            if (window.isOverlayMode) {
                document.body.classList.add('overlay-mode');
                document.getElementById('overlay-placeholder').style.display = 'flex';
                const appWrapper = document.getElementById('app-wrapper');
                if (appWrapper) appWrapper.style.display = 'none';

                window.triggerOverlayDraw = async function (drawnWinners, fullPool, useClaimFeature, chosenAnim, claimDuration) {
                    animationSelect.value = chosenAnim;
                    claimDurationInput.value = claimDuration;
                    document.getElementById('overlay-placeholder').style.display = 'none';
                    await displayMultiWinnerModals(drawnWinners, fullPool, useClaimFeature);
                };

                window.updateOverlayCountdown = function (timeLimit) {
                    const countdown = multiWinnerModalContainer.querySelector('.modal-claim-countdown');
                    if (countdown) {
                        countdown.textContent = `${timeLimit}s`;
                    }
                };

                window.setOverlayClaimStatus = function (status, name) {
                    const countdown = multiWinnerModalContainer.querySelector('.modal-claim-countdown');
                    const instruction = multiWinnerModalContainer.querySelector('.modal-claim-instruction');
                    const buttons = multiWinnerModalContainer.querySelector('.modal-claim-buttons');

                    if (countdown) {
                        if (status === 'confirmed') {
                            countdown.textContent = "Congratulations, User confirmed!";
                            countdown.className = "modal-claim-countdown confirmed";
                            if (instruction) instruction.style.display = 'none';
                        } else if (status === 'failed') {
                            if (instruction) instruction.style.display = 'none';
                            countdown.innerHTML = `WAKE UP ${name},<br>You chalked your win! GG's better luck next time.`;
                            countdown.className = "modal-claim-countdown failed";
                            if (buttons) buttons.style.display = 'flex';
                        }
                    }
                };

                window.updateOverlayChatMessage = function (chatData) {
                    const chatLog = multiWinnerModalContainer.querySelector('.modal-winner-chat-log');
                    if (chatLog) {
                        if (chatLog.classList.contains('waiting')) {
                            chatLog.classList.remove('waiting');
                        }
                        chatLog.style.display = 'block';
                        const li = document.createElement('li');
                        li.textContent = `${chatData.sender.username}: ${chatData.content}`;
                        chatLog.append(li);
                        chatLog.scrollTop = chatLog.scrollHeight;
                    }
                };

                window.clearOverlay = function () {
                    multiWinnerModalContainer.style.display = 'none';
                    document.body.classList.remove('modal-active');
                    document.getElementById('overlay-placeholder').style.display = 'flex';
                };
            }

            // Remove characters in Unicode block U+E0000..U+E007F (supplementary special-purpose plane - tag characters)
            const SPECIAL_TAGS_REGEX = /[\u{E0000}-\u{E007F}]/gu;
            function sanitizeUnicodeTagCharacters(str) {
                if (typeof str !== 'string') return str;
                return str.replace(SPECIAL_TAGS_REGEX, '');
            }

            function showScreen(scr) {
                loginScreen.style.display = 'none';
                mainScreen.style.display = 'none';
                if (scr === 'login') loginScreen.style.display = 'flex';
                if (scr === 'main') mainScreen.style.display = 'block';
            }

            function setSettingsState(disabled) {
                settingsPanel.querySelectorAll('input:not([type="checkbox"]), select:not(#animation-select), button#start-giveaway-button').forEach(el => el.disabled = disabled);
                subOnlyCheckbox.disabled = disabled;

                const rangeInputs = settingsPanel.querySelectorAll('input[type="range"]');
                rangeInputs.forEach(input => input.disabled = disabled);
                followLengthValue.setAttribute('contenteditable', !disabled);

                if (disabled) {
                    winnerClaimCheckbox.disabled = true;
                    claimDurationInput.disabled = true;
                } else {
                    updateClaimSettingsState();
                }
                animationSelect.disabled = disabled ? isDrawInProgress : false;
            }

            function updateDrawButtonState() {
                drawButton.disabled = isDrawInProgress;
            }

            function getStoredData() { return JSON.parse(localStorage.getItem('kickGiveawayDB') || '{}'); }

            function saveState() {
                if (!kickChannelName) return;
                const allData = getStoredData();
                allData[kickChannelName] = {
                    settings: {
                        keyword: keywordInput.value,
                        winnerCount: winnerCountInput.value,
                        subOnly: subOnlyCheckbox.checked,
                        subMultiplier: subMultiplierSlider.value,
                        followLength: followLengthSlider.value,
                        subLength: subLengthSlider.value,
                        winnerClaim: winnerClaimCheckbox.checked,
                        repeatWinners: repeatWinnersCheckbox.checked,
                        claimDuration: claimDurationInput.value,
                        animation: animationSelect.value,
                    },
                    winners: winners,
                };
                localStorage.setItem('kickGiveawayDB', JSON.stringify(allData));
            }

            function loadStateForChannel(channelName) {
                resetSession();
                const allData = getStoredData();
                const channelData = allData[channelName];

                if (channelData) {
                    const { settings, winners: storedWinners } = channelData;
                    keywordInput.value = settings.keyword || '';
                    winnerCountInput.value = settings.winnerCount || '1';
                    subOnlyCheckbox.checked = settings.subOnly || false;
                    subMultiplierSlider.value = settings.subMultiplier || '1';
                    subMultiplierValue.textContent = settings.subMultiplier || '1';

                    followLengthSlider.value = settings.followLength || '0';
                    followLengthValue.textContent = settings.followLength || '0';
                    subLengthSlider.value = settings.subLength || '0';
                    subLengthValue.textContent = settings.subLength || '0';

                    winnerClaimCheckbox.checked = settings.winnerClaim || false;
                    repeatWinnersCheckbox.checked = settings.repeatWinners || false;
                    claimDurationInput.value = settings.claimDuration || '30';
                    animationSelect.value = settings.animation || 'wheel';
                    winners = storedWinners || [];
                } else {
                    keywordInput.value = ''; winnerCountInput.value = '1'; subOnlyCheckbox.checked = false;
                    subMultiplierSlider.value = '1'; subMultiplierValue.textContent = '1';
                    followLengthSlider.value = '0'; followLengthValue.textContent = '0';
                    subLengthSlider.value = '0'; subLengthValue.textContent = '0';
                    winnerClaimCheckbox.checked = false; claimDurationInput.value = '30'; repeatWinnersCheckbox.checked = false;
                    animationSelect.value = 'wheel';
                    winners = [];
                }
                updateWinnersListUI();
                updateClaimSettingsState();
            }

            function loadInitialState() {
                const lastChannel = localStorage.getItem('kickGiveawayLastChannel');
                if (lastChannel) channelInput.value = lastChannel;
            }

            async function handleLogin() {
                const channelName = channelInput.value.trim().toLowerCase();
                if (!channelName) { alert("Please enter a channel name."); return; }
                connectButton.disabled = true; connectButton.textContent = "Connecting...";
                try {
                    const r = await fetch(`https://kick.com/api/v2/channels/${channelName}`);
                    if (!r.ok) throw new Error("Channel not found or API error.");
                    const data = await r.json();
                    if (!data.chatroom?.id) throw new Error("Could not get Chatroom ID.");

                    kickChannelName = data.slug;
                    kickChannelSlug = data.slug;
                    kickChatroomId = data.chatroom.id;

                    let startDate = new Date();
                    if (data.user && data.user.email_verified_at) {
                        startDate = new Date(data.user.email_verified_at);
                    } else if (data.created_at) {
                        startDate = new Date(data.created_at);
                    }

                    const now = new Date();
                    const diffTime = Math.abs(now - startDate);
                    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

                    followLengthSlider.max = diffDays;
                    if (parseInt(followLengthSlider.value) > diffDays) {
                        followLengthSlider.value = diffDays;
                        followLengthValue.textContent = diffDays;
                    }

                    localStorage.setItem('kickGiveawayLastChannel', kickChannelName);
                    connectedChannelName.textContent = kickChannelName;
                    loadStateForChannel(kickChannelName);
                    showScreen('main');
                } catch (err) {
                    alert(`Login error: ${err.message}`);
                } finally {
                    connectButton.disabled = false; connectButton.textContent = "Connect";
                }
            }

            const WS_URL = 'wss://ws-us2.pusher.com/app/32cbd69e4b950bf97679?protocol=7&client=js&version=8.4.0&flash=false';
            function connectToKickChat() {
                if (ws && ws.readyState === WebSocket.OPEN) ws.close();
                ws = new WebSocket(WS_URL);
                ws.onmessage = handleWebSocketMessage;
                ws.onerror = (err) => console.error(`WebSocket Error: ${err.message}`);
                ws.onclose = (ev) => {
                    console.warn(`WebSocket closed. Code: ${ev.code}`);
                    if (isGiveawayRunning) { statusMessage.textContent = "Connection lost!"; statusMessage.className = 'status-error'; }
                };
            }

            function handleWebSocketMessage(e) {
                let pkt; try { pkt = JSON.parse(e.data); } catch { return; }
                const event = pkt.event;
                const data = pkt.data ? JSON.parse(pkt.data) : {};

                if (event === 'pusher:connection_established') {
                    ws.send(JSON.stringify({ event: 'pusher:subscribe', data: { auth: '', channel: `chatrooms.${kickChatroomId}.v2` } }));
                } else if (event === 'pusher_internal:subscription_succeeded') {
                    const modeText = giveawayKeyword === '' ? 'Connected to chat! Entries are open!' : `Connected to chat! Waiting for "${giveawayKeyword}".`;
                    statusMessage.textContent = modeText;
                    statusMessage.className = 'status-connected';
                } else if (event === 'App\\Events\\ChatMessageEvent') {
                    handleChatMessage(data);
                }
            }

            function startGiveaway() {
                resetSession();
                giveawayKeyword = keywordInput.value.trim().toLowerCase();
                isGiveawayRunning = true;
                setSettingsState(true);
                connectToKickChat();
            }

            function handleChatMessage(data) {
                data.content = sanitizeUnicodeTagCharacters(data.content || '');

                if (activeModalClaim && data.sender.username.toLowerCase() === activeModalClaim.winnerName) {
                    const modalChatLog = activeModalClaim.modalWrapper.querySelector('.modal-winner-chat-log');
                    if (modalChatLog) {
                        if (modalChatLog.classList.contains('waiting')) {
                            modalChatLog.classList.remove('waiting');
                        }
                        modalChatLog.style.display = 'block';
                        const li = document.createElement('li');
                        li.textContent = `${data.sender.username}: ${data.content}`;
                        modalChatLog.append(li);
                        modalChatLog.scrollTop = modalChatLog.scrollHeight;
                    }
                    if (overlayWindow && !overlayWindow.closed) {
                        overlayWindow.updateOverlayChatMessage(data);
                    }
                    activeModalClaim.confirm();
                    return;
                }

                if (lastClaimWinner && data.sender.username.toLowerCase() === lastClaimWinner.name.toLowerCase()) {
                    const li = document.createElement('li');
                    li.textContent = `${data.sender.username}: ${data.content}`;
                    claimChatLog.append(li);
                    claimChatLog.scrollTop = claimChatLog.scrollHeight;
                    if (claimInterval) {
                        clearInterval(claimInterval);
                        claimInterval = null;
                        lastClaimWinner.confirmed = true;
                        claimCountdown.textContent = "Confirmed!";
                        claimCountdown.className = 'confirmed';
                        claimConfirmButton.style.display = 'block';
                        updateWinnersListUI();
                        saveState();
                    }
                }

                const modalWinner = modalChatWinners.find(w => w.name === data.sender.username.toLowerCase());
                if (modalWinner) {
                    if (modalWinner.mode === 'below') {
                        if (modalWinner.logElement.classList.contains('waiting')) {
                            modalWinner.logElement.classList.remove('waiting');
                        }
                        if (modalWinner.logElement.style.display !== 'block') {
                            modalWinner.logElement.style.display = 'block';
                        }
                        const li = document.createElement('li');
                        li.textContent = `${data.sender.username}: ${data.content}`;
                        modalWinner.logElement.append(li);
                        modalWinner.logElement.scrollTop = modalWinner.logElement.scrollHeight;
                    } else if (modalWinner.mode === 'replace') {
                        if (!modalWinner.hasChatStarted) {
                            modalWinner.hasChatStarted = true;
                            modalWinner.titleEl.textContent = `Winner: ${data.sender.username}`;
                            modalWinner.animationBoxEl.innerHTML = '';
                            modalWinner.animationBoxEl.style.display = 'block';

                            const newLog = document.createElement('ul');
                            newLog.className = 'modal-winner-chat-log';
                            newLog.style.display = 'block';
                            newLog.style.height = '100%';
                            newLog.addEventListener('wheel', preventPageScroll);
                            newLog.addEventListener('wheel', (e) => e.stopPropagation());

                            modalWinner.animationBoxEl.appendChild(newLog);
                            modalWinner.logElement = newLog;
                        }
                        const li = document.createElement('li');
                        li.textContent = `${data.sender.username}: ${data.content}`;
                        modalWinner.logElement.append(li);
                        modalWinner.logElement.scrollTop = modalWinner.logElement.scrollHeight;
                    }
                }


                if (!isGiveawayRunning || participants.has(data.sender.username)) return;
                const userMessage = data.content.trim().toLowerCase();
                if (giveawayKeyword === '' || userMessage === giveawayKeyword) {
                    addParticipant(data.sender);
                }
            }


            function addParticipant(sender) {
                const existingLi = [...participantList.children].find(li => li.textContent === sender.username);
                if (existingLi) return;


                const subBadge = (sender.identity?.badges || []).find(b => b.type === 'subscriber' || b.type === 'founder');
                const isSub = !!subBadge;


                if (subOnlyCheckbox.checked && !isSub) return;


                const minSubMonths = parseInt(subLengthSlider.value) || 0;
                const userSubMonths = subBadge ? (subBadge.count || 0) : 0;

                if (minSubMonths > 0 && userSubMonths < minSubMonths) return;

                participants.add(sender.username);
                const entryCount = isSub ? parseInt(subMultiplierSlider.value) : 1;
                for (let i = 0; i < entryCount; i++) allEntries.push(sender.username);

                const li = document.createElement('li');
                li.textContent = sender.username;
                if (isSub) {
                    li.classList.add('subscriber');
                    li.title = `Subscriber (${entryCount}x Entries)`;
                }
                participantList.prepend(li);
                participantCount.textContent = participants.size;
                updateDrawButtonState();
            }


            async function checkFollowAge(channelSlug, username, minDays) {
                if (minDays <= 0) return true;
                try {
                    const r = await fetch(`https://kick.com/api/v2/channels/${channelSlug}/users/${username}`);
                    if (!r.ok) return false;
                    const data = await r.json();

                    if (!data.following_since) return false;

                    const followDate = new Date(data.following_since);
                    const now = new Date();
                    const diffTime = Math.abs(now - followDate);
                    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

                    return diffDays >= minDays;
                } catch (e) {
                    console.error("Follow check failed", e);
                    return null;
                }
            }



            function startPendingAnimation(requestedCount) {
                document.body.classList.add('modal-active');
                multiWinnerModalContainer.style.display = 'flex';
                multiWinnerModalContainer.innerHTML = '';

                const count = requestedCount;
                const topRowCount = (count <= 3) ? count : Math.ceil(count / 2);


                let row1, row2;
                row1 = document.createElement('div');
                row1.className = 'modal-row';
                multiWinnerModalContainer.appendChild(row1);

                if (count > 3) {
                    row2 = document.createElement('div');
                    row2.className = 'modal-row';
                    multiWinnerModalContainer.appendChild(row2);
                }

                const selectedAnim = animationSelect.value;
                if (pendingAnimationInterval) clearInterval(pendingAnimationInterval);


                const animationBoxes = [];


                for (let i = 0; i < count; i++) {
                    const modalInstance = modalTemplate.firstElementChild.cloneNode(true);
                    if (i < topRowCount) row1.appendChild(modalInstance);
                    else row2.appendChild(modalInstance);

                    const content = modalInstance.querySelector('.modal-content');
                    const titleEl = content.querySelector('.winner-title-text');
                    titleEl.textContent = "Drawing...";
                    const animationBox = content.querySelector('.winner-animation-box');


                    const btn = content.querySelector('.modal-confirm-button');
                    btn.style.visibility = 'hidden';

                    animationBoxes.push(animationBox);


                    if (selectedAnim === 'wheel') {
                        animationBox.innerHTML = `<div class="wheel-animation-container"><ul class="wheel-list" style="transform: none; transition: none;"></ul></div>`;
                        const ul = animationBox.querySelector('ul');
                        ul.style.animation = "infiniteSpin 0.15s linear infinite";

                        populateWheelList(ul);
                    } else if (selectedAnim === 'char-scramble') {
                        animationBox.innerHTML = '<h1 class="winner-name"></h1>';
                    } else {

                        animationBox.innerHTML = '<h1 class="winner-name"></h1>';
                    }
                }



                let pendingPool = allEntries.length > 0 ? allEntries : ["Wait...", "Loading...", "Drawing..."];
                while (pendingPool.length < 50) pendingPool = pendingPool.concat(pendingPool);

                pendingAnimationInterval = setInterval(() => {
                    animationBoxes.forEach(box => {
                        if (selectedAnim === 'wheel') {



                        } else if (selectedAnim === 'char-scramble') {
                            const el = box.querySelector('h1');
                            const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!?*&%';
                            let output = '';
                            for (let i = 0; i < 10; i++) {
                                const winningNumber = getLocalRandomNumber(chars.length);
                                output += chars[winningNumber];
                            }
                            el.textContent = output;
                        } else {

                            const el = box.querySelector('h1');
                            const winningNumber = getLocalRandomNumber(pendingPool.length);
                            el.textContent = pendingPool[winningNumber];
                        }
                    });
                }, 60);
            }

            function populateWheelList(ul) {
                let pendingPool = allEntries.length > 0 ? allEntries : ["Wait...", "Loading..."];

                for (let i = 0; i < 50; i++) {
                    const li = document.createElement('li');
                    li.textContent = pendingPool[i % pendingPool.length];
                    ul.appendChild(li);
                }
            }

            function stopPendingAnimation() {
                if (pendingAnimationInterval) {
                    clearInterval(pendingAnimationInterval);
                    pendingAnimationInterval = null;
                }
            }

            function getLocalRandomNumber(max_number) {
                // Use Web Crypto API for cryptographically strong local randomness
                const arr = new Uint32Array(1);
                crypto.getRandomValues(arr);
                return arr[0] % max_number;
            }

            async function getWinningNumber(max_number) {
                // Validate the pool size before calling the API
                if (!Number.isInteger(max_number) || max_number < 1) {
                    console.error('getWinningNumber: invalid max_number:', max_number);
                    return { winningNumber: 1, wasRandomOrg: false };
                }

                const randomOrgUrl = `https://www.random.org/integers/?num=1&min=1&max=${max_number}&col=1&base=10&format=plain&rnd=new`;

                // --- Attempt 1: Direct fetch (works when CORS headers are present or in non-browser contexts) ---
                try {
                    const response = await fetch(randomOrgUrl);
                    if (!response.ok) throw new Error(`HTTP ${response.status}`);
                    const text = await response.text();
                    const parsed = parseInt(text.trim().split('\n')[0]);
                    if (isNaN(parsed) || parsed < 1 || parsed > max_number) throw new Error('Unexpected response value');
                    console.log(`[Random.org] Direct — drew #${parsed} of ${max_number}`);
                    return { winningNumber: parsed, wasRandomOrg: true };
                } catch (err) {
                    console.warn('[Random.org] Direct fetch failed (likely CORS):', err.message);
                }

                // --- Attempt 2: CORS proxy (bypasses CORS restriction for browser-based apps) ---
                try {
                    const proxyUrl = `https://corsproxy.io/?url=${encodeURIComponent(randomOrgUrl)}`;
                    const response = await fetch(proxyUrl);
                    if (!response.ok) throw new Error(`HTTP ${response.status}`);
                    const text = await response.text();
                    const parsed = parseInt(text.trim().split('\n')[0]);
                    if (isNaN(parsed) || parsed < 1 || parsed > max_number) throw new Error('Unexpected proxy response');
                    console.log(`[Random.org] Via CORS proxy — drew #${parsed} of ${max_number}`);
                    return { winningNumber: parsed, wasRandomOrg: true };
                } catch (err) {
                    console.warn('[Random.org] CORS proxy failed:', err.message);
                }

                // --- Attempt 3: Local crypto fallback (no network required) ---
                const localNum = getLocalRandomNumber(max_number) + 1; // 1-based
                console.warn(`[Random.org] All API attempts failed — using local crypto RNG. Drew #${localNum} of ${max_number}`);
                return { winningNumber: localNum, wasRandomOrg: false };
            }

            function cancelActiveClaim() {
                if (activeModalClaim) {
                    if (activeModalClaim.interval) {
                        clearInterval(activeModalClaim.interval);
                    }
                    activeModalClaim = null;
                }
                if (claimInterval) {
                    clearInterval(claimInterval);
                    claimInterval = null;
                }
                if (lastClaimWinner && lastClaimWinner.confirmed === false) {
                    lastClaimWinner.confirmed = 'failed';
                    updateWinnersListUI();
                    saveState();
                }
                lastClaimWinner = null;
                claimSection.style.display = 'none';
                claimChatLog.innerHTML = '';
                modalChatWinners = [];
                multiWinnerModalContainer.style.display = 'none';
                document.body.classList.remove('modal-active');
                isDrawInProgress = false;
                resetButton.disabled = false;
                animationSelect.disabled = false;
                updateDrawButtonState();

                if (overlayWindow && !overlayWindow.closed) {
                    safeOverlayCall('clearOverlay');
                }
            }

            async function drawWinner() {
                cancelActiveClaim();
                isDrawInProgress = true;
                updateDrawButtonState();
                resetButton.disabled = true;
                animationSelect.disabled = true;

                const requestedWinnerCount = parseInt(winnerCountInput.value) || 1;
                const useClaimFeature = winnerClaimCheckbox.checked && requestedWinnerCount === 1;

                // Build the pending pool — unique eligible entrants (with duplicates for weighted entries)
                let pendingPool = [...allEntries];

                if (pendingPool.length === 0) {
                    alert("There are no participants in the giveaway!");
                    finishDrawCycle();
                    return;
                }

                const uniqueEligible = [...new Set(pendingPool)].length;
                const finalCountToDraw = Math.min(requestedWinnerCount, uniqueEligible);

                const winnersToDraw = [];
                const minFollowDays = parseInt(followLengthSlider.value) || 0;

                startPendingAnimation(finalCountToDraw);

                let apiErrorOccurred = false;

                for (let i = 0; i < finalCountToDraw; i++) {
                    if (pendingPool.length === 0) break;

                    // Step 1: getWinningNumber is the top-level draw function.
                    // max_number = pendingPool.length → sent to Random.org API URL
                    // The API returns a 1-based number which becomes winningNumber.
                    const max_number = pendingPool.length;
                    const res = await getWinningNumber(max_number);
                    const winningNumber = res.winningNumber;   // 1-based index from Random.org
                    const wasRandomOrg = res.wasRandomOrg;

                    // Step 2: winningNumber directly picks the winner from pendingPool (no retry needed)
                    const candidateName = pendingPool[winningNumber - 1];

                    // Step 3: Optional follow-age check
                    let isValid = true;
                    if (minFollowDays > 0) {
                        const checkResult = await checkFollowAge(kickChannelSlug, candidateName, minFollowDays);
                        if (checkResult === null) {
                            apiErrorOccurred = true;
                            break;
                        }
                        isValid = checkResult;
                        await new Promise(r => setTimeout(r, 200));
                    }

                    // Step 4: Remove candidate from pool (regardless of validity) then record if valid
                    pendingPool = pendingPool.filter(n => n !== candidateName);

                    if (isValid) {
                        const winnerData = {
                            name: candidateName,
                            timestamp: new Date().toISOString(),
                            confirmed: !useClaimFeature,
                            randomnessSource: wasRandomOrg ? 'random.org' : 'local',
                            ticketNumber: winningNumber
                        };
                        winnersToDraw.push(winnerData);
                    } else {
                        // Didn't pass follow check — try one more slot from remaining pool
                        i--;
                    }
                }

                stopPendingAnimation();

                if (apiErrorOccurred) {
                    document.body.classList.remove('modal-active');
                    multiWinnerModalContainer.style.display = 'none';
                    alert("Error while checking Follow Duration!");
                    finishDrawCycle();
                    return;
                }

                if (winnersToDraw.length === 0) {
                    document.body.classList.remove('modal-active');
                    multiWinnerModalContainer.style.display = 'none';
                    alert("There are no eligible participants! (Follow Duration too strict?)");
                    finishDrawCycle();
                    return;
                }

                winners.push(...winnersToDraw);

                // Only remove from pool if repeat winners is NOT allowed
                if (!repeatWinnersCheckbox.checked) {
                    winnersToDraw.forEach(w => {
                        allEntries = allEntries.filter(n => n !== w.name);
                        participants.delete(w.name);
                    });
                }
                updateDrawButtonState();
                updateWinnersListUI();

                // Step 5: Pass the predetermined winner name to the chosen animation
                if (overlayWindow && !overlayWindow.closed) {
                    safeOverlayCall('triggerOverlayDraw', winnersToDraw, allEntries.concat(winnersToDraw.map(w => w.name)), useClaimFeature, animationSelect.value, parseInt(claimDurationInput.value));
                }

                await displayMultiWinnerModals(winnersToDraw, allEntries.concat(winnersToDraw.map(w => w.name)), useClaimFeature);

                if (useClaimFeature) {
                    lastClaimWinner = winnersToDraw[0];
                }

                isDrawInProgress = false;
                resetButton.disabled = false;
                animationSelect.disabled = false;
                updateDrawButtonState();
            }

            function displayMultiWinnerModals(drawnWinners, fullPool, useClaimFeature) {
                return new Promise(resolve => {
                    multiWinnerModalContainer.style.display = 'flex';






                    const existingInstances = multiWinnerModalContainer.querySelectorAll('.modal-instance');
                    const canReuse = existingInstances.length === drawnWinners.length;

                    if (!canReuse) {

                        multiWinnerModalContainer.innerHTML = '';
                    }


                    let row1, row2;
                    if (!canReuse) {
                        const count = drawnWinners.length;
                        const topRowCount = (count <= 3) ? count : Math.ceil(count / 2);
                        row1 = document.createElement('div');
                        row1.className = 'modal-row';
                        multiWinnerModalContainer.appendChild(row1);
                        if (count > 3) {
                            row2 = document.createElement('div');
                            row2.className = 'modal-row';
                            multiWinnerModalContainer.appendChild(row2);
                        }
                    } else {

                    }

                    const animationPromises = drawnWinners.map((winner, index) => {
                        let modalWrapper;

                        if (canReuse) {
                            modalWrapper = existingInstances[index];
                        } else {
                            const count = drawnWinners.length;
                            const topRowCount = (count <= 3) ? count : Math.ceil(count / 2);
                            modalWrapper = modalTemplate.firstElementChild.cloneNode(true);
                            if (index < topRowCount) row1.appendChild(modalWrapper);
                            else row2.appendChild(modalWrapper);
                        }

                        const titleEl = modalWrapper.querySelector('.winner-title-text');
                        const animationBoxEl = modalWrapper.querySelector('.winner-animation-box');
                        const confirmButton = modalWrapper.querySelector('.modal-confirm-button');
                        const chatLogEl = modalWrapper.querySelector('.modal-winner-chat-log');
                        const badgeEl = modalWrapper.querySelector('.randomness-source-badge');

                        if (badgeEl) {
                            badgeEl.className = 'randomness-source-badge';
                            const badgeTextEl = badgeEl.querySelector('.badge-text');
                            if (winner.randomnessSource === 'random.org') {
                                badgeEl.classList.add('random-org');
                                badgeTextEl.textContent = `Verified by Random.org API (Drawn: #${winner.ticketNumber})`;
                            } else {
                                badgeEl.classList.add('fallback');
                                badgeTextEl.textContent = `Verified by local cryptographic RNG (Drawn: #${winner.ticketNumber})`;
                            }
                        }

                        confirmButton.textContent = "OK";
                        confirmButton.style.visibility = 'hidden';


                        const newBtn = confirmButton.cloneNode(true);
                        confirmButton.parentNode.replaceChild(newBtn, confirmButton);

                        newBtn.addEventListener('click', () => {
                            if (window.isOverlayMode) {
                                modalWrapper.classList.add('is-hidden');
                                if (window.opener && !window.opener.closed) {
                                    window.opener.finishDrawCycle();
                                }
                                return;
                            }

                            modalWrapper.classList.add('is-hidden');

                            const showChatLogsBelow = drawnWinners.length <= 3;
                            const replaceAnimationBoxMode = drawnWinners.length > 3;

                            if (showChatLogsBelow || replaceAnimationBoxMode) {
                                modalChatWinners = modalChatWinners.filter(w => w.name !== winner.name.toLowerCase());
                            }

                            if (useClaimFeature && drawnWinners.length === 1) {
                                handleWinnerClaim();
                            }
                        });



                        return runDrawAnimation(fullPool, winner.name, animationBoxEl).then(() => {
                            titleEl.textContent = "Winner:";

                            const showChatLogsBelow = drawnWinners.length <= 3;
                            const replaceAnimationBoxMode = drawnWinners.length > 3;

                            if (showChatLogsBelow) {

                                chatLogEl.style.display = 'block';
                                chatLogEl.classList.add('waiting');

                                chatLogEl.addEventListener('wheel', preventPageScroll);
                                chatLogEl.addEventListener('wheel', (e) => e.stopPropagation());
                                modalChatWinners.push({ name: winner.name.toLowerCase(), logElement: chatLogEl, mode: 'below' });
                            } else if (replaceAnimationBoxMode) {
                                modalChatWinners.push({
                                    name: winner.name.toLowerCase(),
                                    animationBoxEl: animationBoxEl,
                                    titleEl: titleEl,
                                    mode: 'replace',
                                    hasChatStarted: false
                                });
                            }

                            if (useClaimFeature && drawnWinners.length === 1) {
                                startModalWinnerClaim(modalWrapper, winner);
                            } else {
                                newBtn.style.visibility = 'visible';
                            }
                        });
                    });
                    Promise.all(animationPromises).then(resolve);
                });
            }

            function startModalWinnerClaim(modalWrapper, winner) {
                const claimContainer = modalWrapper.querySelector('.modal-claim-container');
                const claimInstruction = modalWrapper.querySelector('.modal-claim-instruction');
                const claimCountdown = modalWrapper.querySelector('.modal-claim-countdown');
                const claimButtons = modalWrapper.querySelector('.modal-claim-buttons');
                const redrawBtn = modalWrapper.querySelector('.modal-redraw-button');
                const cancelBtn = modalWrapper.querySelector('.modal-cancel-button');

                claimContainer.style.display = 'flex';
                claimButtons.style.display = 'flex';
                claimInstruction.style.display = 'block';
                claimCountdown.className = 'modal-claim-countdown';
                claimInstruction.textContent = "If this is you, enter something into the chat before your time runs out.";

                let timeLimit = parseInt(claimDurationInput.value) || 30;
                claimCountdown.textContent = `${timeLimit}s`;

                activeModalClaim = {
                    winnerName: winner.name.toLowerCase(),
                    modalWrapper: modalWrapper,
                    confirm: () => {
                        clearInterval(modalClaimInterval);
                        winner.confirmed = true;
                        updateWinnersListUI();
                        saveState();

                        claimCountdown.textContent = "Congratulations, User confirmed!";
                        claimCountdown.className = "modal-claim-countdown confirmed";
                        claimInstruction.style.display = 'none';

                        if (overlayWindow && !overlayWindow.closed) {
                            safeOverlayCall('setOverlayClaimStatus', 'confirmed', winner.name);
                        }

                        // Close the modal after 2 seconds
                        setTimeout(() => {
                            modalWrapper.classList.add('is-hidden');
                            activeModalClaim = null;
                            finishDrawCycle();
                            if (overlayWindow && !overlayWindow.closed) {
                                safeOverlayCall('clearOverlay');
                            }
                        }, 2000);
                    }
                };

                const modalClaimInterval = setInterval(() => {
                    timeLimit--;
                    claimCountdown.textContent = `${timeLimit}s`;
                    if (overlayWindow && !overlayWindow.closed) {
                        safeOverlayCall('updateOverlayCountdown', timeLimit);
                    }
                    if (timeLimit <= 0) {
                        clearInterval(modalClaimInterval);
                        winner.confirmed = 'failed';
                        updateWinnersListUI();
                        saveState();

                        claimInstruction.style.display = 'none';
                        claimCountdown.innerHTML = `WAKE UP ${winner.name},<br>You chalked your win! GG's better luck next time.`;
                        claimCountdown.className = "modal-claim-countdown failed";
                        claimButtons.style.display = 'flex';

                        activeModalClaim = null;

                        if (overlayWindow && !overlayWindow.closed) {
                            safeOverlayCall('setOverlayClaimStatus', 'failed', winner.name);
                        }
                    }
                }, 1000);

                activeModalClaim.interval = modalClaimInterval;

                redrawBtn.onclick = () => {
                    if (window.isOverlayMode) {
                        modalWrapper.classList.add('is-hidden');
                        if (window.opener && !window.opener.closed) {
                            window.opener.drawWinner();
                        }
                        return;
                    }
                    clearInterval(modalClaimInterval);
                    modalWrapper.classList.add('is-hidden');
                    activeModalClaim = null;
                    finishDrawCycle();
                    if (overlayWindow && !overlayWindow.closed) {
                        overlayWindow.clearOverlay();
                    }
                    drawWinner();
                };

                cancelBtn.onclick = () => {
                    if (window.isOverlayMode) {
                        modalWrapper.classList.add('is-hidden');
                        if (window.opener && !window.opener.closed) {
                            window.opener.cancelActiveClaim();
                        }
                        return;
                    }
                    clearInterval(modalClaimInterval);
                    modalWrapper.classList.add('is-hidden');
                    activeModalClaim = null;
                    finishDrawCycle();
                    if (overlayWindow && !overlayWindow.closed) {
                        overlayWindow.clearOverlay();
                    }
                };
            }

            function runDrawAnimation(pool, finalWinner, animationBoxEl) {
                return new Promise((resolve) => {
                    const animationType = animationSelect.value;
                    const animations = {
                        'slot-machine': animateSlotMachine,
                        'char-scramble': animateCharScramble,
                        'wheel': animateWheel,
                    };
                    animations[animationType](pool, finalWinner, animationBoxEl, resolve);
                });
            }

            function animateSlotMachine(pool, finalWinner, animationBoxEl, resolve) {
                animationBoxEl.innerHTML = '<h1 class="winner-name"></h1>';
                const winnerNameEl = animationBoxEl.querySelector('.winner-name');
                const localInterval = setInterval(() => {
                    if (pool.length > 0) {
                        const winningNumber = getLocalRandomNumber(pool.length);
                        winnerNameEl.textContent = pool[winningNumber];
                    } else {
                        winnerNameEl.textContent = '...';
                    }
                }, 75);
                setTimeout(() => {
                    clearInterval(localInterval);
                    winnerNameEl.textContent = finalWinner;
                    winnerNameEl.classList.add('winner');
                    resolve();
                }, 3500);
            }

            function animateCharScramble(pool, finalWinner, animationBoxEl, resolve) {
                animationBoxEl.innerHTML = '<h1 class="winner-name"></h1>';
                const winnerNameEl = animationBoxEl.querySelector('.winner-name');
                const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!?*&%';
                let frame = 0; const totalFrames = 150;
                const localInterval = setInterval(() => {
                    let output = ''; let completed = true;
                    for (let i = 0; i < finalWinner.length; i++) {
                        const winningNumber = getLocalRandomNumber(chars.length);
                        const from = finalWinner[i], to = chars[winningNumber];
                        const progress = Math.min(frame / (totalFrames * 0.5 + i * 5), 1);
                        if (progress < 1) completed = false;
                        output += (Math.random() < progress) ? from : to;
                    }
                    winnerNameEl.textContent = output;
                    if (completed) {
                        clearInterval(localInterval);
                        winnerNameEl.classList.add('winner');
                        resolve();
                    }
                    frame++;
                }, 40);
            }

            function animateWheel(pool, finalWinner, animationBoxEl, resolve) {
                animationBoxEl.innerHTML = `<div class="wheel-animation-container"><ul class="wheel-list"></ul></div>`;
                const wheelContainer = animationBoxEl.querySelector('.wheel-animation-container');
                const wheelList = animationBoxEl.querySelector('.wheel-list');


                let uniquePool = [...new Set(pool)];


                let noisePool = uniquePool.filter(n => n !== finalWinner);


                if (noisePool.length === 0) {
                    noisePool = [finalWinner];
                }
                while (noisePool.length < 10) noisePool = noisePool.concat(noisePool);


                const cycles = Math.ceil(200 / noisePool.length);
                let repeatedPool = [];
                for (let c = 0; c < cycles; c++) {
                    const shuffled = [...noisePool];

                    for (let i = shuffled.length - 1; i > 0; i--) {
                        const winningNumber = getLocalRandomNumber(i + 1);
                        [shuffled[i], shuffled[winningNumber]] = [shuffled[winningNumber], shuffled[i]];
                    }
                    repeatedPool.push(...shuffled);
                }


                const targetIndex = repeatedPool.length - Math.floor(noisePool.length / 2) - 1;
                repeatedPool[targetIndex] = finalWinner;


                repeatedPool.forEach((name, index) => {
                    const li = document.createElement('li');
                    li.textContent = name;
                    if (index === targetIndex) li.classList.add('winner');
                    wheelList.appendChild(li);
                });


                setTimeout(() => {
                    wheelList.style.transform = `translateY(calc(5.3125rem - ${targetIndex * 3.125}rem))`;
                }, 100);

                wheelList.addEventListener('transitionend', () => {
                    wheelList.classList.add('finished');
                    wheelList.style.transition = 'none';
                    resolve();
                }, { once: true });
            }

            function handleWinnerClaim() {
                claimSection.style.display = 'flex';
                claimWinnerName.textContent = lastClaimWinner.name;

                claimCountdown.className = '';
                claimConfirmButton.style.display = 'none';

                if (claimChatLog.children.length > 0) {
                    lastClaimWinner.confirmed = true;
                    claimCountdown.textContent = "Confirmed!";
                    claimCountdown.className = 'confirmed';
                    claimConfirmButton.style.display = 'block';
                    updateWinnersListUI();
                    saveState();
                    claimInterval = null;
                } else {
                    let t = parseInt(claimDurationInput.value);
                    claimCountdown.textContent = `${lastClaimWinner.name}, you have ${t} seconds to confirm...`;
                    claimInterval = setInterval(() => {
                        t--;
                        claimCountdown.textContent = `${lastClaimWinner.name}, you have ${t} seconds to confirm...`;
                        if (t <= 0) {
                            clearInterval(claimInterval);
                            claimInterval = null;
                            claimCountdown.textContent = "Time is up!";
                            claimCountdown.className = 'failed';
                            claimConfirmButton.style.display = 'block';
                            lastClaimWinner.confirmed = 'failed';
                            updateWinnersListUI();
                            saveState();
                        }
                    }, 1000);
                }
            }

            function finishDrawCycle() {
                cancelActiveClaim();
            }

            function updateWinnersListUI() {
                winnersList.innerHTML = '';
                winners.forEach(winner => {
                    const li = document.createElement('li');
                    if (winner.confirmed === true) li.classList.add('confirmed');
                    if (winner.confirmed === 'failed') li.classList.add('failed');

                    const nameWrapper = document.createElement('div');
                    nameWrapper.style.display = 'flex';
                    nameWrapper.style.alignItems = 'center';
                    nameWrapper.style.minWidth = '0';

                    const nameSpan = document.createElement('span');
                    nameSpan.className = 'winner-name-span';
                    nameSpan.textContent = winner.name;
                    nameSpan.title = winner.name;
                    nameWrapper.appendChild(nameSpan);

                    const sourceTag = document.createElement('span');
                    if (winner.randomnessSource === 'random.org') {
                        sourceTag.className = 'winner-source-tag random-org';
                        sourceTag.textContent = `R.org (#${winner.ticketNumber || '?'})`;
                        sourceTag.title = `Drawn via Random.org API (Number: ${winner.ticketNumber || '?'})`;
                    } else {
                        sourceTag.className = 'winner-source-tag fallback';
                        sourceTag.textContent = `Local (#${winner.ticketNumber || '?'})`;
                        sourceTag.title = `Drawn via local cryptographic RNG (Number: ${winner.ticketNumber || '?'})`;
                    }
                    nameWrapper.appendChild(sourceTag);

                    const dateSpan = document.createElement('span');
                    dateSpan.className = 'winner-date-span';
                    const locale = 'en-US';
                    dateSpan.textContent = new Date(winner.timestamp).toLocaleString(locale, { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' });
                    li.appendChild(nameWrapper); li.appendChild(dateSpan);
                    winnersList.prepend(li);
                });
                winnersCount.textContent = winners.length;
            }

            function resetSession() {
                if (ws && ws.readyState === WebSocket.OPEN) ws.close();
                isGiveawayRunning = false;
                setSettingsState(false);
                statusMessage.textContent = 'Press "Start" to connect to the chat.';
                statusMessage.className = 'status-waiting';
                participants.clear();
                allEntries = [];
                participantList.innerHTML = '';
                participantCount.textContent = '0';
                claimChatLog.innerHTML = '';
                modalChatWinners = [];
                if (activeModalClaim && activeModalClaim.interval) {
                    clearInterval(activeModalClaim.interval);
                }
                activeModalClaim = null;
                updateDrawButtonState();
            }

            function updateClaimSettingsState() {
                const isMultiWinner = parseInt(winnerCountInput.value) > 1;
                winnerClaimCheckbox.disabled = isMultiWinner;
                if (isMultiWinner) winnerClaimCheckbox.checked = false;
                claimDurationInput.disabled = isMultiWinner || !winnerClaimCheckbox.checked;
            }

            function preventPageScroll(event) {
                const element = event.currentTarget;
                const { scrollTop, scrollHeight, clientHeight } = element;
                const deltaY = event.deltaY;
                const isAtBottom = scrollTop + clientHeight >= scrollHeight - 1;
                const isAtTop = scrollTop === 0;
                if ((deltaY > 0 && isAtBottom) || (deltaY < 0 && isAtTop)) {
                    event.preventDefault();
                }
            }



            function init() {
                const openOverlayBtn = document.getElementById('open-overlay-button');
                if (openOverlayBtn) {
                    openOverlayBtn.addEventListener('click', () => {
                        const url = window.location.href.split('?')[0] + '?overlay=true';
                        overlayWindow = window.open(url, 'KickRaffleOverlay', 'width=1000,height=700,menubar=no,toolbar=no,location=no,status=no');
                    });
                }

                loadInitialState();
                connectButton.addEventListener('click', handleLogin);
                channelInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') connectButton.click(); });
                headerMenuToggle.addEventListener('click', () => headerMenuDropdown.classList.toggle('active'));
                window.addEventListener('click', (e) => { if (!headerMenuContainer.contains(e.target)) headerMenuDropdown.classList.remove('active'); });
                changeChannelButton.addEventListener('click', () => { if (confirm("You will be returned to the channel selection screen. Are you sure?")) { showScreen('login'); resetSession(); } });
                clearAllDataButton.addEventListener('click', () => { if (confirm("WARNING! All settings and winner lists for all channels will be permanently deleted. Are you sure?")) { localStorage.removeItem('kickGiveawayDB'); window.location.reload(); } });

                winnerCountInput.addEventListener('input', () => {
                    let value = parseInt(winnerCountInput.value);
                    if (isNaN(value) || value < 1) winnerCountInput.value = 1;
                    if (value > 10) winnerCountInput.value = 10;
                    updateClaimSettingsState();
                });

                winnerClaimCheckbox.addEventListener('change', updateClaimSettingsState);
                startGiveawayButton.addEventListener('click', startGiveaway);
                drawButton.addEventListener('click', drawWinner);
                resetButton.addEventListener('click', resetSession);
                claimConfirmButton.addEventListener('click', finishDrawCycle);
                settingsPanel.addEventListener('change', saveState);


                subMultiplierSlider.addEventListener('input', (e) => { subMultiplierValue.textContent = e.target.value; saveState(); });
                followLengthSlider.addEventListener('input', (e) => { followLengthValue.textContent = e.target.value; saveState(); });
                subLengthSlider.addEventListener('input', (e) => { subLengthValue.textContent = e.target.value; saveState(); });

                followLengthValue.addEventListener('blur', function () {
                    let val = parseInt(this.textContent);
                    let max = parseInt(followLengthSlider.max) || 365;

                    if (isNaN(val) || val < 0) val = 0;
                    if (val > max) val = max;

                    this.textContent = val;
                    followLengthSlider.value = val;
                    saveState();
                });


                followLengthValue.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        this.blur();
                    }
                });

                followLengthValue.addEventListener('click', function (e) {
                    if (this.getAttribute('contenteditable') === 'true') {
                        e.preventDefault();
                        this.focus();
                    }
                });

                updateClaimSettingsState();

                const scrollableElements = document.querySelectorAll(
                    '#participant-list, #winners-list, #claim-chat-log, #multi-winner-modal-container'
                );

                scrollableElements.forEach(el => {
                    el.addEventListener('wheel', preventPageScroll);
                });

                if (window.location.search.includes('unlock_test')) {
                    const sandbox = document.getElementById('test-sandbox');
                    if (sandbox) {
                        sandbox.style.display = 'flex';
                        const btn = document.getElementById('add-test-participants-btn');
                        btn.onclick = () => {
                            addParticipant({ username: "user1", identity: { badges: [] } });
                            addParticipant({ username: "user2", identity: { badges: [] } });
                            addParticipant({ username: "user3", identity: { badges: [] } });
                        };
                    }
                }
            }
            init();
        });
    </script>

</body>

</html>